  "nodes": [
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map((item) => {\n  const update = item.json;\n\n  const message = update.message || null;\n  const callbackQuery = update.callback_query || null;\n\n  const from = message?.from || callbackQuery?.from || {};\n  const chat = message?.chat || callbackQuery?.message?.chat || {};\n\n  const text = message?.text || '';\n  const callbackData = callbackQuery?.data || '';\n\n  let updateType = 'unknown';\n\n  if (message) {\n    updateType = 'message';\n  }\n\n  if (callbackQuery) {\n    updateType = 'callback_query';\n  }\n\n  return {\n    json: {\n      update_id: update.update_id || null,\n\n      update_type: updateType,\n\n      telegram_user_id: from.id || null,\n      username: from.username || null,\n      first_name: from.first_name || null,\n      last_name: from.last_name || null,\n\n      chat_id: chat.id || null,\n      message_id: message?.message_id || callbackQuery?.message?.message_id || null,\n\n      text,\n      callback_data: callbackData,\n\n      is_start_command: text === '/start'\n    }\n  };\n});"
      },
