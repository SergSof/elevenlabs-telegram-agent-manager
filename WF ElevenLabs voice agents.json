    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\n\nlet agents = item.agents_json || [];\n\nif (typeof agents === 'string') {\n  try {\n    agents = JSON.parse(agents);\n  } catch (error) {\n    agents = [];\n  }\n}\n\nif (!Array.isArray(agents)) {\n  agents = [];\n}\n\nconst chatId = $('Normalize Telegram Update').item.json.chat_id;\n\nlet text = '';\nlet replyMarkup = null;\n\nif (agents.length === 0) {\n  text = [\n    'Hello. Your Telegram account has been registered.',\n    '',\n    'No ElevenLabs voice agents are connected to your account yet.'\n  ].join('\\n');\n} else {\n  text = [\n    'Hello. Your Telegram account has been registered.',\n    '',\n    'Please select an ElevenLabs voice agent to manage:'\n  ].join('\\n');\n\n  replyMarkup = {\n    inline_keyboard: agents.map((agent) => [\n      {\n        text: agent.agent_name,\n        callback_data: `select_agent:${agent.id}`\n      }\n    ])\n  };\n}\n\nreturn [\n  {\n    json: {\n      chat_id: chatId,\n      agents,\n      has_agents: agents.length > 0,\n      text,\n      reply_markup: replyMarkup\n    }\n  }\n];"
      },
