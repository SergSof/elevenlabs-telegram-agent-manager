      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COALESCE(\n    (\n      SELECT JSON_ARRAYAGG(\n        JSON_OBJECT(\n          'id', va.id,\n          'agent_name', va.agent_name,\n          'elevenlabs_agent_id', va.elevenlabs_agent_id\n        )\n      )\n      FROM voice_agents va\n      WHERE va.user_id = tu.id\n        AND va.is_active = TRUE\n    ),\n    JSON_ARRAY()\n  ) AS agents_json\nFROM telegram_users tu\nWHERE tu.id = {{ $('Get Telegram User').item.json.id }}\nLIMIT 1;",
